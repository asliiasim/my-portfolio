---
import svgNew from '../assets/new.svg'

const testimonials = [
  {
    comment: `"Asli is the rare PMM who interviews 85 buyers, synthesises what they actually care about, and turns it into a narrative that sales adopts immediately. The repositioning she led genuinely changed how we sell."`,
    author: {
      name: `[Name TBC]`,
      pos: `[Title TBC] · B2B SaaS telecoms scale-up`,
      pic: `https://images.pexels.com/photos/2709386/pexels-photo-2709386.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
    },
    cls: `rotate-2 -translate-y-10`
  },
  {
    comment: `"She built our entire event GTM infrastructure across six flagship shows in twelve months — the messaging, the partner materials, the SDR cadences, the battlecards. The SPS campaign alone produced 156 MQLs."`,
    author: {
      name: `[Name TBC]`,
      pos: `[Title TBC] · Canonical`,
      pic: `https://images.pexels.com/photos/2128819/pexels-photo-2128819.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
    },
    cls: `-rotate-2 -translate-x-10 z-5`
  },
  {
    comment: `"Asli managed one of our most demanding accounts as sole owner for 1.5 years. Her reporting automation saved the team hundreds of hours and her results were consistently above benchmark."`,
    author: {
      name: `[Name TBC]`,
      pos: `[Title TBC] · PHD Media / Omnicom`,
      pic: `https://images.pexels.com/photos/2169429/pexels-photo-2169429.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2`
    },
    cls: `rotate-2 translate-x-5 z-5`
  },
]
---

<section>
    <div class="max-w-4xl mx-auto pb-20 px-10 overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="flex relative">
          <h1 class="text-3xl">Here's what my clients are saying about my work</h1>
          <img src={svgNew.src} alt="new" width="40" class="absolute -right-3 md:-right-10 bottom-0" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 py-30 gap-y-6">
        {testimonials.map(item => (
          <div class={`flex flex-col gap-3 p-5 pr-15 bg-white border-2 shadow-[6px_6px_0px_rgba(0,0,0,0.3)] ${item.cls}`}>
            <p>{item.comment}</p>
            <div class="flex items-center gap-2">
              <div class="size-11 rounded-full border overflow-hidden shrink-0">
                <img src={item.author.pic} alt="" class="w-full h-full object-cover" />
              </div>
              <div>
                <h3 class="font-medium">{item.author.name}</h3>
                <p class="text-sm text-gray-500">{item.author.pos}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
</section>
