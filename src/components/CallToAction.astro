---
import svgPinkStar from '../assets/pink-star.svg'
import Button from './Button.astro'
---

<section class="px-3" id="contact">
    <div class="max-w-3xl mx-auto bg-white text-center flex flex-col gap-4 border-3 shadow-[8px_8px_0px_rgba(0,0,0,0.3)] relative p-10">
      <h1 class="text-3xl">Let's build something that converts.</h1>
      <p class="text-lg max-w-lg mx-auto">I'm looking for senior PMM roles in Europe — B2B SaaS, deep tech, and product-led companies where positioning, GTM, and enablement need to work together. If that's you, let's talk.</p>
      <div class="flex justify-center gap-4 flex-wrap">
        <Button text="Get in touch →" link="mailto:aslialimesimsek@gmail.com" target="_self" />
        <a href="https://linkedin.com/in/aslialimesimsek" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 underline underline-offset-4 text-sm">LinkedIn →</a>
      </div>
      <img src={svgPinkStar.src} alt="svg" width="80" class="absolute -top-10 right-20" />
    </div>
</section>
