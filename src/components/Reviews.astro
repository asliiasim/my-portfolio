---
import svgNew from '../assets/new.svg'

const testimonials = [
  {
    quote: "She is quick to suggest good ideas while developing both the processes powering effective go-to-market strategies and developing the narratives for each product launch. I highly recommend Asli for the full range of Marketing, Channel and Product Marketing roles.",
    name: "Oliver Happy",
    title: "ProdMind Co-founder · Advisor (FinTech, Web3, AI)",
    linkedinUrl: "https://www.linkedin.com/in/oliverhappy/",
    verificationNote: "Verified LinkedIn recommendation · July 2025",
  },
  {
    quote: "Not everyone has the character to maintain this level of quality and commitment under pressure.",
    name: "Senior Colleague",
    title: "Robotics & Automation, Enterprise Tech",
    linkedinUrl: null,
    verificationNote: "Team feedback · December 2025",
  },
]
---

<script>
import { gsap } from 'gsap';

document.addEventListener('DOMContentLoaded', function () {
    const ticker = document.querySelector('#testimonial-ticker') as any;

    if (!ticker) return;
    
    // Clone items for infinite scroll effect
    Array.from(ticker.children).forEach((el: any) => {
        ticker.appendChild(el.cloneNode(true));
    });

    // Animate from right to left (continuous scroll)
    gsap.to(ticker, {
        x: -(ticker.scrollWidth / 2),
        duration: 60,
        ease: 'none',
        repeat: -1,
    });
});
</script>

<section>
    <div class="max-w-full pb-20">
      <div class="max-w-4xl mx-auto px-10 mb-10">
        <div class="flex relative">
          <h1 class="text-3xl">What others say</h1>
          <img src={svgNew.src} alt="new" width="40" class="absolute -right-3 md:-right-10 bottom-0" />
        </div>
      </div>

      <div class="overflow-hidden border-y border-gray-200 py-8 mb-10">
        <div class="flex gap-8 md:gap-12 px-10" id="testimonial-ticker">
          {testimonials.map(t => (
            <div class="flex-shrink-0 w-96 border-l-4 border-[var(--yellow)] pl-6 py-4">
              <p class="text-base leading-relaxed mb-6">"{t.quote}"</p>
              <div>
                {t.linkedinUrl ? (
                  <a href={t.linkedinUrl} target="_blank" rel="noopener noreferrer" class="font-bold hover:underline text-sm">{t.name}</a>
                ) : (
                  <p class="font-bold text-sm">{t.name}</p>
                )}
                <p class="text-xs text-gray-500">{t.title}</p>
                <p class="text-[9px] uppercase tracking-widest text-gray-400 mt-1">{t.verificationNote}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="max-w-4xl mx-auto px-10">
        <p class="text-sm text-gray-500 mb-6">
          Additional references available on request. Full recommendation history on
          <a href="https://linkedin.com/in/aslialimesimsek" target="_blank" rel="noopener noreferrer" class="underline underline-offset-4">LinkedIn</a>.
        </p>

        <div>
          <p class="text-xs font-black tracking-widest uppercase text-gray-500 mb-6">Impact by the numbers</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="border-l-2 border-black pl-4">
              <p class="font-medium">156 MQLs from one email campaign</p>
              <p class="text-sm text-gray-500">1,121 contacts, 45% open rate. SPS 2025, Canonical.</p>
            </div>
            <div class="border-l-2 border-black pl-4">
              <p class="font-medium">150+ partners enabled</p>
              <p class="text-sm text-gray-500">NVIDIA, Qualcomm, Bosch Rexroth and more. Co-marketing materials and training adopted across the ecosystem.</p>
            </div>
            <div class="border-l-2 border-black pl-4">
              <p class="font-medium">65% email open rate</p>
              <p class="text-sm text-gray-500">SDR sequences rebuilt on repositioned messaging — B2B SaaS telecoms, segmented commercial decision-maker list. Industry benchmark 30–40%.</p>
            </div>
            <div class="border-l-2 border-black pl-4">
              <p class="font-medium">15+ live public assets</p>
              <p class="text-sm text-gray-500">Whitepapers, webinar, blog posts, and case studies — all verifiable at ubuntu.com and canonical.com.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
</section>
