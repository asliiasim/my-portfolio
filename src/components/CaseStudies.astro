---
import svgUnderline from '../assets/underline.svg'
import execNvidiaJetson from '../assets/exec-nvidia-jetson.png'
import execRoscon2025 from '../assets/exec-roscon-2025.png'
import execBotmindFleet from '../assets/exec-botmind-fleet.png'
import execInfotainmentKanzi from '../assets/exec-infotainment-kanzi.jpg'
import exec8kInfotainment from '../assets/exec-8k-infotainment.jpg'
import execMwcDashboard from '../assets/exec-mwc-infotainment-dashboard.png'
import execMwcTesting from '../assets/exec-mwc-infotainment-testing.png'
import execMwcAutomotiveDemo from '../assets/exec-mwc-automotive-demo.png'

const cases = [
  {
    id: 'case-cra',
    company: 'Canonical · IoT & Devices',
    role: 'Product Marketing Manager · Canonical IoT & Devices',
    title: 'Turning a regulation into a market moment',
    threadLine: 'Most companies treat regulation as a legal problem. We treated it as a positioning opportunity and built a GTM motion that made Canonical the authoritative voice on device compliance before competitors knew what to say.',
    challengeParas: [
      'EU device makers had no clear compliance path for the Cyber Resilience Act (CRA), a regulation in force since December 2024 with mandatory enforcement in 2027 that could block market access.',
      'The market was anxious. Canonical had the answer. The job was turning that into a GTM motion.',
    ],
    note: 'CRA = EU Cyber Resilience Act, mandatory device security regulation',
    approachParas: [
      'A sequenced content campaign: educate first (awareness blog), qualify second (whitepaper), convert third (webinar + event activation).',
      'Each stage was designed to produce a different buyer action, not just consume content.',
    ],
    actionParas: [
      'Built the full CRA positioning narrative with Ubuntu Core as the CRA-compliant embedded OS. Refreshed two whitepapers with distinct audience variants.',
      'Commissioned and managed three paid ad creatives (drone / robotic arm / motherboard) tested across LinkedIn and Meta.',
      'Scripted and produced the live webinar "Securing Ubuntu deployments for IoT and edge devices" (December 11, with Canonical\'s Robotics Product Manager and Senior Field Engineer, Ubuntu IoT & Devices).',
      'Activated the narrative across SPS 2025, Embedded World 2025, and CES 2026 with partner-aligned messaging for 150+ ecosystem partners including NVIDIA, Qualcomm, Bosch Rexroth, Intel, Advantech, and congatec.',
      'Ran paid and organic social experiments, including video content filmed with Canonical\'s Robotics Product Manager, to test long and short form content performance for whitepaper promotion.',
      '**SPS 2025 execution:** 156 MQLs from email campaign (1,121 targeted contacts, 45% open rate, segmented B2B industrial automation exhibitor list).',
    ],
    executionImages: [
      { src: execNvidiaJetson.src, alt: 'NVIDIA Jetson Thor demo - AI deployment proof', caption: 'NVIDIA Jetson Thor AI capabilities demonstration' },
    ],
    resultsParas: [
      'The CRA campaign became Canonical\'s primary IoT GTM narrative for 2025 to 2026.',
      'The SPS 2025 email campaign delivered 156 MQLs from 1,121 targeted contacts at a 45% open rate. All four content assets remain publicly accessible.',
    ],
    keyLearning: 'Buyers who engage with educational content before seeing a product pitch are a different kind of lead. The whitepaper download wasn\'t just MOFU. It was the qualifier that told sales exactly which regulation the buyer was worried about.',
    metrics: [
      { value: '156 MQLs', label: 'from SPS 2025 (1,121 contacts, 45% open rate, segmented B2B list of industrial automation exhibitors)' },
      { value: '150+', label: 'partners enabled with CRA positioning and co-marketing materials' },
      { value: '5 live assets', label: '3 whitepapers + 1 webinar + 1 blog post' },
    ],
    links: [
      { url: 'https://ubuntu.com/engage/cra-yocto-core', label: 'Yocto or Ubuntu Core for embedded devices? A comparison guide for CTOs' },
      { url: 'https://ubuntu.com/engage/cra-regulations-for-ubuntu', label: 'Prepare Your Devices for the EU\'s Cyber Resilience Act' },
      { url: 'https://ubuntu.com/engage/securing-ubuntu-devices', label: 'Securing Ubuntu Deployments for IoT and edge devices (whitepaper)' },
      { url: 'https://ubuntu.com/engage/webinar-securing-ubuntu-devices', label: 'Key Steps to Secure Ubuntu Deployments (webinar, December 11)' },
      { url: 'https://canonical.com/blog/canonical-qualcomm-dragonwing-iq9075', label: 'Canonical and Qualcomm Dragonwing IQ9075 partnership' },
      { url: 'https://www.linkedin.com/feed/update/urn:li:activity:7405250165994962945/', label: 'LinkedIn: whitepaper campaign video' },
      { url: 'https://www.linkedin.com/feed/update/urn:li:activity:7437780959732801537/', label: 'LinkedIn: Yocto vs Ubuntu Core video' },
    ],
    howIDidIt: [
      'Mapped 25+ embedded OS alternatives. Identified Yocto (an open-source build system for custom embedded Linux) as the primary CTO comparison point. Structured the whitepaper as a decision framework, not a product brochure.',
      'Ran 3 ad creative variants simultaneously on LinkedIn and Meta: drone (UAV/robotics buyers), robotic arm (industrial), circuit board (general embedded). Goal: find highest download rate per audience.',
      'SPS 2025 email (Marketo/Jimminy): subject "Are you heading to SPS 2025 this month?" / preheader "Booth #122, Hall 6" / dual CTAs: Calendly meeting booking + webinar on-demand / SPS floor map embedded in reminder email.',
      'Ubuntu Pro for Devices battlecard: 2 pages covering qualifying questions, objection handling, FAQ on CRA/DISA-STIG/FIPS 140/ISO 27001/IEC 62443, key personas (CXO/CTO, Security Architect, Embedded Developer, Product Manager).',
      'Video content: filmed interview with the Robotics Product Manager for organic and paid LinkedIn/Meta distribution. Tested long-form vs short-form performance for whitepaper awareness.',
    ],
  },
  {
    id: 'case-events',
    company: 'Canonical · IoT & Devices',
    role: 'Product Marketing Manager · Canonical IoT & Devices',
    title: 'Six different buyers. One product. One narrative that worked for all of them.',
    threadLine: 'Robotics developers, automotive OEMs, industrial engineers, and enterprise IT. Same product, completely different reasons to buy. Here\'s how one modular narrative covered all of them across six flagship events in twelve months.',
    challengeParas: [
      'Ubuntu Core needed to be positioned credibly across six completely different markets at six flagship events in twelve months.',
      'One narrative wouldn\'t cover all of them. Five separate narratives wouldn\'t hold together.',
    ],
    note: null,
    approachParas: [
      'A tiered event system with modular messaging: one core positioning, vertically adapted per show, partner co-activated at each.',
      'T1 (horizontal): CES 2026, Embedded World 2025. Category-level positioning.',
      'T2 (vertical): SPS 2025 (industrial), ROSCon Singapore (robotics), ctrlX AUTOMATION Week (automation).',
      'T3 (community): Ubuntu IoT Day Singapore. Developer conversion.',
    ],
    actionParas: [
      'Designed and executed GTM across all six shows: CES 2026 (automotive + AI infotainment, Booth #10562, Las Vegas, January 6 to 9), SPS 2025 (industrial automation, Booth #122 Hall 6, Nuremberg, November 25 to 27), ROSCon Singapore (robotics community, 27 to 29 November), Embedded World 2025 (multi-vertical, Nuremberg), ctrlX AUTOMATION Week (Bosch Rexroth co-hosted webinar: "Open Robotics, Open Minds: open source robotic innovation with ROS 2", November 18 to 20), and Ubuntu IoT Day Singapore (May 27).',
      'Built 6 distinct demo narratives. Each opened with the vertical pain point, demonstrated the Ubuntu Core feature that solves it, and closed with a qualifying question for sales handoff.',
      'Managed pre-event alignment across Sales, Product, Events, and 150+ ecosystem partners including NVIDIA, Qualcomm, congatec, Bosch Rexroth, Advantech, BotMind, and Kässbohrer.',
      'Built the monthly DBR (business review) deck for 200+ stakeholders covering pipeline visibility, messaging alignment, and event prioritisation.',
      'Also planned the Embedded World 2026 GTM including silicon partner demo planning, booth logistics, and joint marketing with Advantech, Avnet, and Witekio. Execution completed by successor team after December 2025 departure.',
      'The infotainment demo built with Rightware during this period was subsequently reused by Canonical at MWC 2026. The work outlasted the tenure.',
      '**ROSCon 2025 proof:** Facebook post reached 60K impressions at 6% engagement rate (3x platform average). Partner co-booth strategy (Canonical + NVIDIA + Advantech + BotMind) generated more qualified conversations than any solo booth would have at four times the cost.',
    ],
    executionImages: [
      { src: execRoscon2025.src, alt: 'ROSCon 2025 Singapore event', caption: 'ROSCon Singapore partner co-booth activation' },
      { src: execBotmindFleet.src, alt: 'Botmind fleet management demo', caption: 'Botmind fleet management system demo' },
      { src: execInfotainmentKanzi.src, alt: 'Kanzi UI infotainment interface', caption: 'Kanzi infotainment UI at CES 2026' },
      { src: exec8kInfotainment.src, alt: '8K infotainment demo', caption: 'Cloud-native 8K infotainment experience' },
      { src: execMwcDashboard.src, alt: 'MWC infotainment system dashboard', caption: 'Infotainment system interface and controls' },
      { src: execMwcTesting.src, alt: 'MWC infotainment development environment', caption: 'Development and testing environment' },
      { src: execMwcAutomotiveDemo.src, alt: 'MWC automotive infotainment application', caption: 'Automotive infotainment application built with Rightware' },
    ],
    resultsParas: [
      'The ROSCon Singapore Facebook post reached 60K impressions at a 6% engagement rate, 3x the platform average.',
      'SPS 2025 delivered 156 MQLs. Events generated 40+ SQLs combined.',
    ],
    keyLearning: 'Partner co-booth strategy is the highest-leverage event investment. At ROSCon, a joint Canonical + NVIDIA + Advantech + BotMind setup generated more qualified conversations than any solo booth would have at four times the cost.',
    metrics: [
      { value: '6% / 60K', label: 'social engagement / impressions from ROSCon Singapore Facebook post (3x platform average)' },
      { value: '6 events', label: 'across 4 countries in 12 months' },
      { value: '40+ SQLs', label: 'generated from event demo narratives and campaigns' },
    ],
    links: [
      { url: 'https://canonical.com/blog/canonical-at-ces-2026', label: 'Meet Canonical at CES 2026: A trusted foundation for your device lifecycle' },
      { url: 'https://canonical.com/blog/future-of-infotainment-canonical-at-ces-2026', label: 'From cloud to dashboard: the future of infotainment at CES 2026' },
      { url: 'https://canonical.com/blog/roscon-2025', label: 'ROSCon 2025 recap' },
      { url: 'https://canonical.com/blog/canonical-qualcomm-dragonwing-iq9075', label: 'Canonical and Qualcomm Dragonwing IQ9075 partnership' },
      { url: 'https://www.linkedin.com/feed/update/urn:li:activity:7414093406936981505/', label: 'LinkedIn: NVIDIA Rubin partnership at CES' },
      { url: 'https://www.linkedin.com/feed/update/urn:li:activity:7401568953216679936/', label: 'LinkedIn: Qualcomm certification partnership' },
      { url: 'https://www.linkedin.com/feed/update/urn:li:activity:7414666128901328896/', label: 'LinkedIn: CES 2026' },
      { url: 'https://www.linkedin.com/feed/update/urn:li:activity:7435011281646084098/', label: 'LinkedIn: MWC 2026 infotainment demo (built with Rightware; reused at MWC 2026)' },
      { url: 'https://www.linkedin.com/feed/update/urn:li:activity:7401302086484652033/', label: 'LinkedIn: SPS 2025' },
      { url: 'https://www.linkedin.com/feed/update/urn:li:activity:7391631618219667456/', label: 'LinkedIn: ctrlX AUTOMATION Week' },
      { url: 'https://ubuntu.com/engage/embedded-world-2026', label: 'Embedded World 2026 (planned before leaving; delivered by successor team)' },
      { url: 'https://ubuntu.com/engage/reducing-risk-for-embedded-devices', label: 'Reducing risk for embedded devices: Advantech, Avnet, Witekio (planned before leaving)' },
    ],
    howIDidIt: [
      'T1 (CES 2026, Embedded World): horizontal category positioning across 4 themes. Core 26 launch messaging / Ubuntu Pro for Devices fleet security / consistent AI model deployment across silicon partners (NVIDIA, Qualcomm, congatec) / cloud-native automotive infotainment development.',
      'T2 (SPS, ROSCon, ctrlX): vertical outcome messaging. Industrial real-time + AMI UEFI one-click boot demo / robotics ROS 2 ecosystem / Bosch Rexroth automation partnership.',
      'T3 (IoT Day Singapore): community + developer conversion focus.',
      '6 distinct demo scripts: each opens with the vertical buyer pain, shows the Ubuntu Core feature that removes it, closes with a qualifying question for sales handoff (e.g. "What\'s your current plan for CRA compliance?").',
      'ROSCon viral post: 6-photo collage including booth setup, NVIDIA Jetson Thor live demo, SIX-AGT humanoid robot, ROSCon \'25 Singapore venue signage, attendee crowd engagement. Posted November 4 on Ubuntu Facebook page. 6% engagement / 60K impressions.',
      'CES 2026 key partner meetings: NVIDIA, Qualcomm, congatec, Kässbohrer. Joint silicon demo scenarios for consistent AI model deployment across device architectures.',
      'DBR deck: monthly 200+ stakeholder presentation covering pipeline visibility by vertical, messaging alignment status, event prioritisation, and partner activation.',
    ],
  },
]
---

<section class="py-20 px-5">
  <div class="max-w-4xl mx-auto space-y-20">

    <div class="relative max-w-md">
      <h2 class="text-4xl font-medium">Case Studies</h2>
      <img src={svgUnderline.src} alt="underline" width="140" class="absolute left-0 -bottom-1" />
    </div>

    {cases.map(c => (
      <article id={c.id} class="border-t-2 border-black pt-10 space-y-6">

        <div class="flex flex-wrap gap-2 items-start justify-between">
          <div>
            <span class="text-xs font-black tracking-widest uppercase bg-black text-white px-2 py-1">{c.company}</span>
            <p class="text-sm text-gray-500 mt-1">{c.role}</p>
          </div>
        </div>

        <h3 class="text-3xl font-medium">{c.title}</h3>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 border-2 border-black">
          {c.metrics.map(m => (
            <div class="p-5 border-b-2 md:border-b-0 md:border-r-2 last:border-0">
              <p class="text-2xl font-bold">{m.value}</p>
              <p class="text-sm text-gray-500">{m.label}</p>
            </div>
          ))}
        </div>

        <p class="italic text-gray-600 border-l-4 border-[var(--yellow)] pl-4">{c.threadLine}</p>

        <details class="border-2 border-black">
          <summary class="p-4 font-bold cursor-pointer select-none hover:bg-gray-50 transition-colors">
            Story
          </summary>
          <div class="space-y-6 p-4 pt-0 border-t-2 border-black">
            <div>
              <h4 class="font-bold text-sm uppercase tracking-widest mb-2">Challenge</h4>
              <div class="space-y-2">
                {c.challengeParas.map(p => <p class="leading-relaxed">{p}</p>)}
              </div>
              {c.note && <p class="text-xs text-gray-400 mt-2">{c.note}</p>}
            </div>
            <div>
              <h4 class="font-bold text-sm uppercase tracking-widest mb-2">Approach</h4>
              <div class="space-y-2">
                {c.approachParas.map(p => <p class="leading-relaxed">{p}</p>)}
              </div>
            </div>
            <div>
              <h4 class="font-bold text-sm uppercase tracking-widest mb-2">Action</h4>
              <div class="space-y-4">
                {c.actionParas.map(p => <p class="leading-relaxed">{p}</p>)}
                {c.executionImages && c.executionImages.length > 0 && (
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                    {c.executionImages.map(img => (
                      <figure>
                        <img src={img.src} alt={img.alt} class="w-full border border-gray-200" />
                        <figcaption class="text-xs text-gray-500 mt-2 text-center italic">{img.caption}</figcaption>
                      </figure>
                    ))}
                  </div>
                )}
              </div>
            </div>
            <div>
              <h4 class="font-bold text-sm uppercase tracking-widest mb-2">Results</h4>
              <div class="space-y-2">
                {c.resultsParas.map(p => <p class="leading-relaxed">{p}</p>)}
              </div>
            </div>
            <div class="border-l-4 border-black pl-4">
              <h4 class="font-bold text-sm uppercase tracking-widest mb-2">Key Learning</h4>
              <p class="leading-relaxed italic">{c.keyLearning}</p>
            </div>
          </div>
        </details>

        {c.links.length > 0 && (
          <div>
            <h4 class="font-bold text-sm uppercase tracking-widest mb-2">Live Links</h4>
            <ul class="space-y-1">
              {c.links.map(l => (
                <li>
                  <a href={l.url} target="_blank" rel="noopener noreferrer" class="text-sm underline underline-offset-4 hover:opacity-70 transition-opacity">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <details class="border-2 border-black">
          <summary class="p-4 font-bold cursor-pointer select-none hover:bg-gray-50 transition-colors">
            How I Did It — Methodology & Execution
          </summary>
          <div class="p-4 pt-0 border-t-2 border-black space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {c.howIDidIt.map((item, idx) => (
                <div class="border-l-4 border-gray-300 pl-4 py-2">
                  <div class="flex gap-2 items-start">
                    <span class="font-bold text-gray-400 shrink-0 text-sm">Step {idx + 1}</span>
                    <p class="text-sm leading-relaxed">{item}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </details>

      </article>
    ))}

  </div>
</section>
