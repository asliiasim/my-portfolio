---
import logoStar from '../assets/logo-star.svg'
import { author } from '../sample'

const links = [
  { label: 'Work', href: '#work' },
  { label: 'About', href: '#about' },
  { label: 'Contact', href: '#contact' },
]
---

<footer class="border-t-4 px-5 md:px-0 py-10 mt-30">
    <div class="max-w-3xl mx-auto flex justify-center flex-col gap-5 md:gap-0 md:grid md:grid-cols-3 items-center">
      <div class="flex-1 font-bold">
        <a href="/" class="flex items-center gap-3 text-xl">
          <img src={logoStar.src} alt="logo" width="30" /> {author.nickname}
        </a>
      </div>
      <div class="text-center">
        <div class="flex gap-4 justify-center mb-2">
          {links.map(l => (
            <a href={l.href} class="text-sm hover:underline">{l.label}</a>
          ))}
        </div>
        <p class="text-sm">© {new Date().getFullYear()} Asli Simsek. All rights reserved.</p>
      </div>
      <div class="flex md:justify-end gap-5">
        <a href="https://linkedin.com/in/aslialimesimsek" target="_blank" rel="noopener noreferrer" class="transition-all duration-200 hover:translate-y-[2px]">
          <i class="ri-linkedin-fill text-2xl"></i>
        </a>
        <a href="mailto:aslialimesimsek@gmail.com" class="transition-all duration-200 hover:translate-y-[2px]">
          <i class="ri-mail-line text-2xl"></i>
        </a>
      </div>
    </div>
</footer>
