---
import svgUnderline from '../assets/underline.svg'

const cases = [
  {
    id: 'case-cra',
    company: 'Canonical · IoT & Devices',
    role: 'Product Marketing Manager · Oct 2025–Present',
    title: 'CRA Compliance GTM — From regulation to pipeline',
    challenge: 'EU device makers had no clear compliance path for the Cyber Resilience Act — a regulation in force since December 2024 with mandatory enforcement in 2027 that could block market access. The market was anxious. Canonical had the answer. The job was turning that into a GTM motion.',
    approach: 'A sequenced content campaign: educate first (awareness blog), qualify second (whitepaper), convert third (webinar + event activation). Each stage was designed to produce a different buyer action, not just consume content.',
    action: 'Built the full CRA positioning narrative — Ubuntu Core as the CRA-compliant embedded OS. Refreshed two whitepapers with distinct audience variants. Commissioned and managed three paid ad creatives (drone / robotic arm / motherboard) tested across LinkedIn and Meta. Scripted and produced the live webinar "Securing Ubuntu deployments for IoT and edge devices" (December 11, Gabriel Aguiar Noury + Lorenzo Medici). Activated the CRA narrative across SPS 2025, Embedded World 2025, and CES 2026 with partner-aligned messaging for 150+ ecosystem partners including NVIDIA, Qualcomm, Bosch Rexroth, Intel, Advantech, and congatec.',
    results: 'The CRA campaign became Canonical\'s primary IoT GTM narrative for 2025–2026. The SPS 2025 email campaign — built on this positioning — delivered 156 MQLs from 1,121 contacts at a 45% open rate. All four assets remain publicly accessible.',
    keyLearning: 'Buyers who engage with educational content before seeing a product pitch are a different kind of lead. The whitepaper download wasn\'t just MOFU — it was the qualifier that told sales exactly which regulation the buyer was worried about.',
    metrics: [
      { value: '156 MQLs', label: 'from SPS 2025 (1,121 contacts, 45% open rate)' },
      { value: '150+', label: 'partners enabled with CRA positioning' },
      { value: '4 live assets', label: '3 whitepapers + 1 webinar on-demand' },
    ],
    links: [
      { url: 'https://ubuntu.com/engage/cra-yocto-core', label: 'Yocto or Ubuntu Core for embedded devices? A comparison guide for CTOs' },
      { url: 'https://ubuntu.com/engage/cra-regulations-for-ubuntu', label: 'Prepare Your Devices for the EU\'s Cyber Resilience Act' },
      { url: 'https://ubuntu.com/engage/securing-ubuntu-devices', label: 'Securing Ubuntu Deployments for IoT and edge devices' },
      { url: 'https://ubuntu.com/engage/webinar-securing-ubuntu-devices', label: 'Key Steps to Secure Ubuntu Deployments for IoT and edge devices (webinar)' },
    ],
    howIDidIt: [
      'Mapped 25+ embedded OS alternatives; identified Yocto as the primary comparison point for CTOs — structured the whitepaper as a CTO decision framework.',
      'Ran 3 ad creative variants on LinkedIn and Meta — drone (UAV/robotics), robotic arm (industrial), circuit board (general embedded) — to find highest download rate.',
      'SPS 2025 email: subject "Are you heading to SPS 2025 this month?" / preheader "Booth #122, Hall 6" / dual CTAs: Calendly meeting + webinar on-demand / SPS floor map embedded in reminder email.',
      'Ubuntu Pro for Devices battlecard: 2 pages covering qualifying questions, objection handling, FAQ covering CRA/DISA-STIG/FIPS/ISO 27001/IEC 62443, and key personas (CXO/CTO, Security Architect, Embedded Dev, Product Manager).',
    ],
  },
  {
    id: 'case-events',
    company: 'Canonical · IoT & Devices',
    role: 'Product Marketing Manager · Oct 2025–Present',
    title: 'Event GTM at Scale — 6 shows, 156 MQLs, 150+ partners',
    challenge: 'Ubuntu Core needed to be positioned credibly across six completely different markets — robotics developers, industrial automation engineers, automotive OEMs, and enterprise IT — at six flagship events in twelve months. One narrative wouldn\'t cover all of them. Five separate narratives wouldn\'t hold together.',
    approach: 'A tiered event system with modular messaging: one core positioning, vertically adapted per show, partner co-activated at each. T1 for horizontal category awareness. T2 for vertical outcome messaging. T3 for community and developer conversion.',
    action: 'Designed and executed GTM across all six shows: CES 2026 (automotive + AI infotainment, Booth #10562, Las Vegas), SPS 2025 (industrial automation, Booth #122 Hall 6, Nuremberg), ROSCon Singapore (robotics community, 27–29 November), Embedded World 2025 (multi-vertical, Nuremberg), ctrlX AUTOMATION Week (Bosch Rexroth co-hosted webinar), and Ubuntu IoT Day Singapore. Built 6 distinct demo narratives — each opening with the vertical pain point, demoing the Ubuntu Core feature that solves it, closing with a qualifying question for sales handoff.',
    results: 'The ROSCon Singapore Facebook post reached 60K impressions at a 6% engagement rate — 3× the platform average. SPS 2025 delivered 156 MQLs. Events generated 40+ SQLs combined.',
    keyLearning: 'Partner co-booth strategy is the highest-leverage event investment. At ROSCon, a joint Canonical + NVIDIA + Advantech + BotMind setup generated more qualified conversations than any solo booth would have at four times the cost.',
    metrics: [
      { value: '6% / 60K', label: 'social engagement / impressions — ROSCon Singapore (3× platform average)' },
      { value: '6 events', label: 'across 4 countries in 12 months' },
      { value: '40+ SQLs', label: 'generated from event demo narratives and campaigns' },
    ],
    links: [
      { url: 'https://canonical.com/blog/roscon-2025', label: 'ROSCon 2025 recap' },
      { url: 'https://canonical.com/blog/canonical-at-ces-2026', label: 'Meet Canonical at CES 2026' },
      { url: 'https://canonical.com/blog/future-of-infotainment-canonical-at-ces-2026', label: 'From cloud to dashboard: the future of infotainment at CES 2026' },
      { url: 'https://ubuntu.com/engage/embedded-world-2026', label: 'Embedded World 2026 (planned before leaving; handed off to team)' },
    ],
    howIDidIt: [
      'T1 (CES, Embedded World): horizontal category positioning — 4 themes: Core 26 launch messaging / Ubuntu Pro for Devices fleet security / consistent AI model deployment across silicon partners / cloud-native automotive infotainment.',
      'T2 (SPS, ROSCon, ctrlX Week): vertical outcome messaging — industrial real-time + AMI UEFI boot demo / robotics ROS 2 ecosystem / Bosch Rexroth automation partnership.',
      'T3 (IoT Day Singapore): community + developer conversion focus.',
      '6 distinct demo scripts: each opens with vertical buyer pain, shows Ubuntu Core feature that removes it, closes with a qualifying question for sales handoff.',
      'ROSCon viral post: 6-photo collage including booth setup, NVIDIA Jetson Thor live demo, humanoid robot, ROSCon \'25 Singapore signage, attendee crowd — posted 4 November on Ubuntu Facebook page.',
      'CES 2026 key partner meetings: NVIDIA, Qualcomm, congatec, Kässbohrer — joint silicon demo scenarios.',
    ],
  },
  {
    id: 'case-vitrifi',
    company: 'B2B SaaS telecoms scale-up',
    role: 'Product Marketing Manager · 2024–2025',
    title: 'B2B SaaS Repositioning — 85+ interviews, one new narrative',
    challenge: 'The product was being sold on features — API efficiency, carrier-grade reliability. Buyers were making decisions on outcomes: how fast can I deploy this, what does it cost to run, how much risk am I taking on? The gap between what sales was saying and what buyers were hearing was closing deals slowly.',
    approach: 'Primary research first. Build the new narrative from what buyers actually said. Then rebuild every enablement surface from that research up — messaging matrix, content hub, onboarding, SDR cadences.',
    action: 'Conducted 85+ structured interviews with CSPs, alt-nets, and wholesale operators — 60 minutes each, three layers: technical, process, commercial. Synthesised into 3 buyer personas and a complete positioning shift: features → operational outcomes (time / cost / risk). Built a 9-segment messaging matrix, 2 content tracks, a Notion-based Content Hub with version control, a Loom video onboarding library, an event reporting framework across 20+ events, and SDR email cadences written in buyer interview language.',
    results: '65% email open rate on repositioned SDR campaigns (benchmark: ~30%). 40% reduction in content turnaround time. 30% reduction in onboarding time. 200+ employees trained. 40+ SQLs from aligned campaigns.',
    keyLearning: 'Repositioning only works if enablement follows. The new narrative generated better leads. The Content Hub meant sales could actually deliver it in the room, without reverting to the feature-led language buyers had already tuned out.',
    metrics: [
      { value: '65%', label: 'email open rate — repositioned SDR campaigns (vs. ~30% benchmark)' },
      { value: '40%', label: 'content turnaround reduction — Content Hub vs. Slack-based requests' },
      { value: '200+', label: 'employees trained in 30% less time via Loom onboarding hub' },
    ],
    links: [],
    howIDidIt: [
      '85+ CSP interviews: 60-min structured format, 3 layers each — technical (features used?), process (how do you deploy/manage?), commercial (how do you make this decision?).',
      'Key insight: operators used the word "risk" 4× more than any feature name — restructured all messaging around risk reduction first.',
      '2-content-track strategy: technical track for CTOs; non-technical track (cost comparison, ROI model, implementation timeline) for Ops and Commercial.',
      'Content Hub: Notion asset library with master docs → versioned variants → daily self-serve — replaced 3-5 day Slack request turnaround with same-day access.',
      'SDR cadences: 3-touch sequence built from buyer interview language, not product specs — subject lines referenced operator pain points verbatim.',
    ],
  },
  {
    id: 'case-phd',
    company: 'PHD Media / Omnicom · UK & Ireland',
    role: 'Digital Marketing Executive · Aug 2022–Mar 2024',
    title: 'Programmatic at Scale — £1M+ budgets, 4 DSPs, +15% ROI',
    challenge: 'Managing £1M+ in programmatic budgets across 4 DSPs simultaneously, with weekly static reporting that arrived too late to affect anything. Manual reconciliation was consuming 40+ hours per week of team time.',
    approach: 'Automate the reporting infrastructure completely first. Then use the time freed to build a more sophisticated audience and bidding strategy than the team had bandwidth for before.',
    action: 'Built an automated dashboard consolidating DV360, Xandr, Yahoo DSP, and Amazon DSP into a single view refreshing every 4 hours. Shifted from static weekly budget allocation to daily rebalancing. Built first-party data activation (CRM → lookalike modelling → sequential TOFU→MOFU→BOFU messaging). Tested contextual targeting as a cookie-deprecation hedge. Curated a private marketplace (PMP) publisher roster. Sole UK and Ireland owner for a luxury fashion brand portfolio for 1.5 years.',
    results: '+15% ROI improvement across client base. 200+ hours saved annually. 75% reduction in manual reporting time.',
    keyLearning: 'Automation creates the conditions for strategy. The dashboard didn\'t just save time — it surfaced insights invisible in weekly snapshots: which DSP outperformed on which day, which creative fatigued faster, which segment was saturated.',
    metrics: [
      { value: '+15%', label: 'ROI improvement — daily multi-DSP optimisation vs. weekly static allocation' },
      { value: '200+ hrs/yr', label: 'saved — automated dashboard vs. manual PDF reporting' },
      { value: '£1M+', label: 'budgets managed — sole owner, UK & Ireland, luxury fashion brand' },
    ],
    links: [
      { url: 'https://www.phdmedia.com', label: 'PHD Media / Omnicom' },
    ],
    howIDidIt: [
      'Dashboard: API pulls from all 4 DSPs → single view, 4-hour refresh, client-facing + internal views.',
      'Daily optimisation: budget shifted to highest-performing platform based on same-day CPM/conversion signals.',
      'PMP curation: direct publisher deals for luxury fashion — brand-safe placements at 25-40% better CPM than open marketplace.',
      'First-party activation: CRM → lookalike modelling → sequential messaging (awareness → consideration → purchase).',
      'Contextual testing: A/B validated performance parity with cookie-dependent targeting; recommended as post-deprecation primary strategy.',
      '4 DSPs: DV360 (premium + YouTube), Xandr (scale + 1P data), Yahoo DSP (contextual reach), Amazon DSP (shopper data + owned inventory).',
    ],
  },
]
---

<section class="py-20 px-5">
  <div class="max-w-4xl mx-auto space-y-20">

    <div class="relative max-w-md">
      <h2 class="text-4xl font-medium">Case Studies</h2>
      <img src={svgUnderline.src} alt="underline" width="140" class="absolute left-0 -bottom-1" />
    </div>

    {cases.map(c => (
      <article id={c.id} class="border-t-2 border-black pt-10 space-y-6">

        <div class="flex flex-wrap gap-2 items-start justify-between">
          <div>
            <span class="text-xs font-black tracking-widest uppercase bg-black text-white px-2 py-1">{c.company}</span>
            <p class="text-sm text-gray-500 mt-1">{c.role}</p>
          </div>
        </div>

        <h3 class="text-3xl font-medium">{c.title}</h3>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 border-2 border-black">
          {c.metrics.map(m => (
            <div class="p-5 border-b-2 md:border-b-0 md:border-r-2 last:border-0">
              <p class="text-2xl font-bold">{m.value}</p>
              <p class="text-sm text-gray-500">{m.label}</p>
            </div>
          ))}
        </div>

        <div class="space-y-4">
          <div>
            <h4 class="font-bold text-sm uppercase tracking-widest mb-1">Challenge</h4>
            <p class="leading-relaxed">{c.challenge}</p>
          </div>
          <div>
            <h4 class="font-bold text-sm uppercase tracking-widest mb-1">Approach</h4>
            <p class="leading-relaxed">{c.approach}</p>
          </div>
          <div>
            <h4 class="font-bold text-sm uppercase tracking-widest mb-1">Action</h4>
            <p class="leading-relaxed">{c.action}</p>
          </div>
          <div>
            <h4 class="font-bold text-sm uppercase tracking-widest mb-1">Results</h4>
            <p class="leading-relaxed">{c.results}</p>
          </div>
          <div class="border-l-4 border-black pl-4">
            <h4 class="font-bold text-sm uppercase tracking-widest mb-1">Key Learning</h4>
            <p class="leading-relaxed italic">{c.keyLearning}</p>
          </div>
        </div>

        {c.links.length > 0 && (
          <div>
            <h4 class="font-bold text-sm uppercase tracking-widest mb-2">Live Links</h4>
            <ul class="space-y-1">
              {c.links.map(l => (
                <li>
                  <a href={l.url} target="_blank" rel="noopener noreferrer" class="text-sm underline underline-offset-4 hover:opacity-70 transition-opacity">
                    {l.label} ↗
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <details class="border-2 border-black">
          <summary class="p-4 font-bold cursor-pointer select-none hover:bg-gray-50 transition-colors">
            How I Did It ↓
          </summary>
          <ul class="p-4 pt-0 space-y-2 border-t-2 border-black">
            {c.howIDidIt.map(item => (
              <li class="flex gap-3 text-sm leading-relaxed">
                <span class="font-bold shrink-0">•</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </details>

      </article>
    ))}

  </div>
</section>
