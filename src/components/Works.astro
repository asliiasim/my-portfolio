---
import Bars from "./Bars.astro"
import svgUnderline from '../assets/underline.svg'
import arrowCard from '../assets/arrow-card.svg'
import caseVitrifi from '../assets/case-vitrifi.svg'
import casePhd from '../assets/case-phd.svg'
import cardCra from '../assets/card-cra.png'
import cardEvents from '../assets/card-events.png'

const portfolio = [
  {
    name: 'Turning a regulation into a market moment',
    desc: `Positioning · GTM · Content · Campaigns · Partner enablement`,
    cover: cardCra.src,
    link: '#case-cra',
    confidential: false,
  },
  {
    name: 'Six different buyers. One product. One narrative that worked for all of them.',
    desc: `Event strategy · Partner activation · Demand gen · Community GTM`,
    cover: cardEvents.src,
    link: '#case-events',
    confidential: false,
  },
  {
    name: '85 interviews. One insight. A new narrative.',
    desc: `Customer research · Positioning · Messaging · Enablement`,
    cover: caseVitrifi.src,
    link: '#case-vitrifi',
    confidential: true,
  },
  {
    name: '200 hours of manual reporting. One dashboard. An entirely different way to work.',
    desc: `Paid media · Automation · Analytics · Multi-platform`,
    cover: casePhd.src,
    link: '#case-phd',
    confidential: true,
  },
]
---

<section class="py-25 space-y-10 px-5" id="work">
    <div class="max-w-md mx-auto relative">
      <h1 class="text-4xl font-medium text-center">Featured Work</h1>
      <p class="text-center text-gray-600 mt-2">Full case studies with live artifacts and public evidence</p>
      <img src={svgUnderline.src} alt="underline" width="140" class="absolute left-50 -bottom-5" />
    </div>

    <div class="max-w-3xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10">
      {portfolio.map(item => (
        <a href={item.link} class="flex flex-col bg-white p-5 group relative transition-all duration-200 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.3)]">
          <div class="w-full h-[200px] overflow-hidden border-2 bg-gray-50">
            <img src={item.cover} alt={item.name} class="w-full h-full object-cover" />
          </div>
          <div class="space-y-1 pt-4">
            <div class="flex pr-2">
              <h2 class="text-xl font-medium flex-1">{item.name}</h2>
              <img src={arrowCard.src} alt="arrow" width="25" />
            </div>
            <p class="mr-20 text-sm text-gray-500">{item.desc}</p>
            {item.confidential && (
              <p class="text-[10px] uppercase tracking-widest text-gray-400 mt-2">Confidential: metrics and methodology shared</p>
            )}
          </div>
          <Bars />
        </a>
      ))}
    </div>
</section>
